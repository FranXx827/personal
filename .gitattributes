# Auto detect text files and perform LF normalization
* text=auto

# Force the following filetypes to have unix eols, but prevent git from
# converting them to CRLF on checkout.
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.vue text eol=lf
*.scss text eol=lf
*.css text eol=lf
*.py text eol=lf
*.md text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.f4v binary
*.webm binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
